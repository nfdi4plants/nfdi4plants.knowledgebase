---
import Papa from 'papaparse'

interface Row {
  [key: string]: string
}

const { csv } = Astro.props as { csv: string }

const result = Papa.parse<Row>(csv.trim(), {
  header: true,
  skipEmptyLines: true
})

const data: Row[] = result.data
const headers = data.length ? Object.keys(data[0]) : []
---

<table>
  <thead>
    <tr>
      {headers.map((h) => <th>{h}</th>)}
    </tr>
  </thead>
  <tbody>
    {data.map((row: Row, i: number) => (
      <tr>
        {headers.map((h) => <td>{row[h]}</td>)}
      </tr>
    ))}
  </tbody>
</table>

<style>
  table {
    display: block;
    overflow-x: auto;
  }
  td {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
</style>